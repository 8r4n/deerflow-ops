{
  "name": "Patronus: A ByteDance DeerFlow Agentic System",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "echo '✅ Codespace ready — edit deer-flow/.env with API keys, then: cd deer-flow && make dev'",
  "containerEnv": {
    "DOCKER_BUILDKIT": "1",
    "DEER_FLOW_EXTENSIONS_CONFIG_PATH": "${containerWorkspaceFolder}/extensions_config.json"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint"
      ]
    },
    "codespaces": {
      "openFiles": [
        "README.md"
      ]
    }
  },
  "forwardPorts": [2024, 2026, 3000, 8001, 8080]
}
